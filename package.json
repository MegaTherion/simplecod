{
  "name": "simplecod",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/core",
    "packages/web"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=packages/web",
    "build": "npm run build --workspace=packages/core && npm run build --workspace=packages/web",
    "test": "npm run test --workspace=packages/core",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "globals": "^17.7.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  }
}
